# ─── TONGAMES – env.example ──────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to git.

# 24-word BIP39 mnemonic for the owner wallet (holds contract keys + pays gas)
OWNER_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24"

# toncenter.com API key (free tier works for testnet)
TON_API_KEY="your-toncenter-api-key"

# Stake per player in nanoTON (1 TON = 1_000_000_000)
STAKE_AMOUNT=1000000000

# Max players per room (2–8, must match GameContract MAX_PLAYERS cap)
MAX_PLAYERS=4

# Wallet version for your mnemonic. Leave commented to auto-detect.
# Valid values: V3R1 | V3R2 | V4 | V5R1
# Tonkeeper        → V4
# TON Wallet (old) → V3R2
# Newer wallets    → V5R1
# WALLET_VERSION=V4

# Set to "true" to deploy on testnet, omit or set "false" for mainnet
TESTNET=true

# Set to "true" to skip TACT recompilation and use existing build/ artifacts
# SKIP_COMPILE=false

# WebSocket server port
PORT=3000
