{
  "name": "tongames-server",
  "version": "1.0.0",
  "description": "TONGAMES WebSocket game server + TON blockchain adapter",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "compile": "tact --config tact.config.json",
    "deploy":  "node scripts/deploy.js",
    "deploy:testnet": "TESTNET=true node scripts/deploy.js",
    "deploy:skip-compile": "SKIP_COMPILE=true node scripts/deploy.js",
    "start":   "node server/index.js",
    "dev":     "node --watch server/index.js"
  },
  "devDependencies": {
    "@tact-lang/compiler": "^1.5.0"
  },
  "dependencies": {
    "@ton/core":   "^0.56.3",
    "@ton/crypto": "^3.2.0",
    "@ton/ton":    "^15.0.0",
    "ws":          "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  }
}